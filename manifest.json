{
  "manifest_version": 3,
  "name": "Better Shorts - YouTube Scroll Stabilizer",
  "version": "1.0.0",
  "description": "Stabilizes YouTube Shorts scroll position when resizing the browser window, keeping the active Short in focus.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}